{
  "name": "posthtml",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "PostHTML — upload HTML plans and get a shareable URL",
  "workspaces": [
    "cli",
    "web"
  ],
  "scripts": {
    "dev": "bun run --cwd web dev",
    "build": "bun run --cwd cli build && bun run --cwd web build",
    "build:web": "bun run --cwd web build",
    "build:cli": "bun run --cwd cli build",
    "lint": "bun run --cwd web lint",
    "test": "echo no tests",
    "clean": "rm -rf cli/dist web/.next"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module"
}
