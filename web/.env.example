# PostHTML — Web App Environment Variables
# Copy this file to .env and fill in your values:
#   cp web/.env.example web/.env

# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → connection details
DATABASE_URL=postgresql://user:password@ep-example-123.us-east-2.aws.neon.tech/neondb?sslmode=require

# Better Auth secret (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=your-secret-key-change-me-in-production

# Base URL of the web app (required by Better Auth for callbacks)
BETTER_AUTH_URL=http://localhost:3000

# Public-facing auth URL (same as BETTER_AUTH_URL in dev, custom domain in prod)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials
# Set up at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- CLI (optional - can also use `ptd setup`) ---
# PTD_API_KEY=your-api-key
# PTD_URL=https://posthtml.vercel.app

# Secret for signing private-post capability tokens (generate with: openssl rand -hex 32)
# POST_TOKEN_SECRET=your-token-secret-change-me-in-production
