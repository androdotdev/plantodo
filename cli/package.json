{
  "name": "@androff/posthtml-cli",
  "version": "0.1.0",
  "description": "PostHTML — CLI tool to upload/delete/list plans",
  "license": "MIT",
  "keywords": [
    "plantodo",
    "ptd",
    "plans",
    "html"
  ],
  "homepage": "https://posthtml.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/androdotdev/plantodo.git"
  },
  "type": "module",
  "bin": {
    "ptd": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf dist",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "echo \"No linter configured\" && exit 0"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "tsup": "^8.5.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
